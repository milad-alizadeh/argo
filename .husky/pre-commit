# --- session isolation: commits belong in worktrees (see AGENTS.md "Session isolation") ---
# Concurrent agent sessions share this checkout; a commit here lands on whatever branch/index
# another session is using. Worktrees pass (git-dir != git-common-dir). Humans deliberately
# committing in the main checkout: ARGO_MAIN_COMMIT=1 git commit ...
if [ -z "$ARGO_MAIN_COMMIT" ] \
   && [ "$(git rev-parse --git-dir 2>/dev/null)" = "$(git rev-parse --git-common-dir 2>/dev/null)" ]; then
  echo "pre-commit: blocked — this is the shared main checkout; implement in a worktree" >&2
  echo "  (git worktree add / EnterWorktree; override: ARGO_MAIN_COMMIT=1 git commit ...)" >&2
  exit 1
fi
# --- end session isolation ---

bunx lint-staged

# --- graphify: committed knowledge graph, refreshed in-commit (installed by setup-graphify) ---
# Refresh + stage the graph INTO this commit, but ONLY in the main working tree — linked
# worktrees are skipped (git-dir != git-common-dir), so feature branches never churn or
# conflict the graph. `graphify update` names every community deterministically from its
# dominant node — no LLM, no key, no churn. Never run `graphify label` here: it re-clusters
# and drops dated backup dirs. No-op until the graph exists.
if command -v graphify >/dev/null 2>&1 && [ -f graphify-out/graph.json ] \
   && [ "$(git rev-parse --git-dir 2>/dev/null)" = "$(git rev-parse --git-common-dir 2>/dev/null)" ]; then
  graphify update . >/dev/null 2>&1 || true
  git add graphify-out >/dev/null 2>&1 || true
fi
# --- end graphify ---
