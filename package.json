{
  "name": "argo",
  "private": true,
  "packageManager": "bun@1.3.3",
  "bin": {
    "argo": "packages/argo-skills/bin/scaffold.mjs"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:stories": "turbo run test:stories",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "scaffold": "node packages/argo-skills/bin/scaffold.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "turbo": "^2.3.3"
  }
}
