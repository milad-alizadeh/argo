{
  "name": "argo",
  "private": true,
  "packageManager": "bun@1.3.3",
  "bin": {
    "argo": "packages/argo-skills/bin/scaffold.mjs"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "format-and-lint": "biome check . --error-on-warnings",
    "format-and-lint:fix": "biome check . --write",
    "test": "turbo run test",
    "test:hooks": "node scripts/worktree-guard.test.mjs && node scripts/hooks-sync.test.mjs",
    "test:stories": "turbo run test:stories",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "check:design-tokens": "sh scripts/check-design-tokens.sh",
    "worktrees:gc": "sh scripts/worktree-gc.sh",
    "hooks:sync": "node packages/argo-skills/bin/hooks-sync.mjs",
    "storybook": "turbo run storybook",
    "build-storybook": "turbo run build-storybook",
    "scaffold": "node packages/argo-skills/bin/scaffold.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "turbo": "^2.3.3"
  }
}
