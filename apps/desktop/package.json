{
  "name": "@argo/desktop",
  "version": "0.1.0",
  "description": "Argo cockpit — a render-only desktop window that observes and steers stock agentic CLI Sessions.",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "boundaries": "bun --bun x depcruise --config scripts/dependency-cruiser.cjs src",
    "test": "vitest run --project=unit",
    "test:stories": "vitest run --project=storybook",
    "test:e2e": "electron-vite build && playwright test",
    "package": "electron-vite build && electron-builder --mac",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@phosphor-icons/react": "^2.1.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.6.2",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "dependency-cruiser": "^18.1.0",
    "electron": "43.1.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.11.0",
    "playwright": "^1.61.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "storybook": "^10.5.2",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.10"
  }
}
